# Copy to .env and fill in. The .env file is gitignored — never commit real keys.

# Web UI password your 4 teammates type to log in.
APP_PASSWORD=agenticai

# Random secret for signing the login cookie. Generate with:
#   openssl rand -hex 32
SECRET_KEY=

# Google AI Studio key — https://aistudio.google.com (Get API Key).
GEMINI_API_KEY=

# serper.dev key for web search — https://serper.dev (free tier, 2500 searches).
SERPER_API_KEY=

# Gemini model (used as the fallback engine). Note: Gemini's free tier is only
# ~20 calls/day even on flash-lite, so it's the backup, not the primary.
MODEL=gemini/gemini-2.5-flash-lite

# Which engine to try first: "ollama" (default — fast, uncapped) or "gemini".
PRIMARY_BACKEND=ollama

# Ollama backup/primary on the VPS (reached over the ollama docker network).
OLLAMA_BASE_URL=http://ollama-tz4d-ollama-1:11434
OLLAMA_MODEL=ollama_chat/kimi-k2.7-code:cloud

# Subdomain Traefik serves the app on (wildcard DNS already resolves it).
APP_DOMAIN=agenticai.srv1487908.hstgr.cloud
